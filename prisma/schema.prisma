// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // bcrypt hashed
  name      String
  role      UserRole @default(ADMIN)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@map("users")
}

enum UserRole {
  ADMIN
  OPERATOR
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  domain    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // WooCommerce Config
  wooUrl            String?
  wooConsumerKey    String?
  wooConsumerSecret String?
  webhookSecret     String?

  // Cargus Config
  cargusUsername String?
  cargusPassword String?
  cargusClientId String?

  // SmartBill Config
  smartbillToken String?
  smartbillEmail String?

  // Relations
  orders    Order[]
  shipments Shipment[]
  invoices  Invoice[]

  @@index([domain])
  @@map("tenants")
}

model Order {
  id        String      @id @default(cuid())
  tenantId  String
  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // WooCommerce Data
  wooOrderId      String
  wooOrderNumber  String?
  
  // Customer Info
  customerName    String
  customerEmail   String
  customerPhone   String?
  
  // Addresses
  shippingAddress Json // { street, city, county, postalCode, country }
  billingAddress  Json
  
  // Order Details
  items     Json // Array of order items
  subtotal  Decimal @db.Decimal(10, 2)
  shipping  Decimal @db.Decimal(10, 2) @default(0)
  tax       Decimal @db.Decimal(10, 2) @default(0)
  total     Decimal @db.Decimal(10, 2)
  currency  String  @default("RON")
  
  // Status
  status         OrderStatus         @default(PENDING)
  paymentStatus  PaymentStatus       @default(PENDING)
  paymentMethod  String?
  
  // Processing
  processedAt DateTime?
  notes       String?   @db.Text
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  shipment Shipment?
  invoice  Invoice?

  @@unique([tenantId, wooOrderId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([customerEmail])
  @@map("orders")
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model Shipment {
  id        String   @id @default(cuid())
  orderId   String   @unique
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Cargus Data
  awbNumber      String?  @unique
  courier        String   @default("Cargus")
  status         ShipmentStatus @default(PENDING)
  
  // Package Details
  weight         Decimal? @db.Decimal(10, 2)
  length         Decimal? @db.Decimal(10, 2)
  width          Decimal? @db.Decimal(10, 2)
  height         Decimal? @db.Decimal(10, 2)
  declaredValue  Decimal? @db.Decimal(10, 2)
  
  // Shipping Details
  shippingCost      Decimal? @db.Decimal(10, 2)
  estimatedDelivery DateTime?
  deliveredAt       DateTime?
  
  // Tracking
  trackingHistory Json?    // Array of tracking events
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([awbNumber])
  @@index([status])
  @@map("shipments")
}

enum ShipmentStatus {
  PENDING
  GENERATED
  PICKED_UP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  RETURNED
  CANCELLED
}

model Invoice {
  id        String   @id @default(cuid())
  orderId   String   @unique
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // SmartBill Data
  invoiceNumber  String
  invoiceSeries  String?
  provider       String   @default("SmartBill")
  
  // Invoice Details
  amount     Decimal @db.Decimal(10, 2)
  tax        Decimal @db.Decimal(10, 2)
  total      Decimal @db.Decimal(10, 2)
  currency   String  @default("RON")
  
  // Status
  status     InvoiceStatus @default(DRAFT)
  issuedAt   DateTime?
  paidAt     DateTime?
  dueDate    DateTime?
  
  // Files
  pdfUrl     String?
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId])
  @@index([status])
  @@map("invoices")
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  SENT
  PAID
  OVERDUE
  CANCELLED
}

model ActivityLog {
  id        String   @id @default(cuid())
  tenantId  String?
  orderId   String?
  
  action    String   // e.g., "order.created", "shipment.generated"
  details   Json?
  userId    String?
  ipAddress String?
  
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([orderId])
  @@map("activity_logs")
}
